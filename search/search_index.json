\u7248\u672c\u200b\u76f8\u6bd4\u200b\u589e\u52a0\u200b\u4e86\u200b\u8bb8\u591a\u200b\u73b0\u4ee3\u200b\u7684\u200b\u6cd5\u5f8b\u200b\u4fdd\u62a4\u200b\u548c\u200b\u79d1\u6280\u200b\u53d1\u5c55\u200b\u76f8\u5173\u200b\u7684\u200b\u66f4\u65b0\u200b\u3002</p>"}, {"location": "about/license/#\u57fa\u672c\u6743\u9650", "title": "\u57fa\u672c\u200b\u6743\u9650", "text": "<ul> <li>\u200b\u81ea\u7531\u200b\u4f20\u64ad\u200b\uff1a\u200b\u60a8\u200b\u53ef\u4ee5\u200b\u81ea\u7531\u200b\u5730\u200b\u590d\u5236\u200b\u548c\u200b\u5206\u53d1\u200b\u539f\u59cb\u200b\u6216\u200b\u4fee\u6539\u200b\u540e\u200b\u7684\u200b\u8f6f\u4ef6\u200b\u7248\u672c\u200b\u3002</li> <li>\u200b\u6e90\u4ee3\u7801\u200b\u516c\u5f00\u200b\uff1a\u200b\u60a8\u200b\u6709\u6743\u200b\u83b7\u53d6\u200b\u3001\u200b\u4fee\u6539\u200b\u548c\u200b\u5206\u53d1\u200b\u8f6f\u4ef6\u200b\u7684\u200b\u6e90\u4ee3\u7801\u200b\u3002</li> <li>\u200b\u65e0\u62c5\u4fdd\u200b\u627f\u8bfa\u200b\uff1a\u200b\u8f6f\u4ef6\u200b\u6309\u200b\u201c\u200b\u73b0\u72b6\u200b\u201d\u200b\u53d1\u5e03\u200b\uff0c\u200b\u6ca1\u6709\u200b\u4efb\u4f55\u200b\u660e\u793a\u200b\u6216\u200b\u6697\u793a\u200b\u7684\u200b\u8d28\u91cf\u200b\u62c5\u4fdd\u200b\u3002</li> </ul>"}, {"location": "about/license/#\u91cd\u8981\u6761\u6b3e", "title": "\u91cd\u8981\u200b\u6761\u6b3e", "text": "<ul> <li>\u200b\u975e\u200b\u4fb5\u5bb3\u200b\u6027\u200b\uff1a\u200b\u4efb\u4f55\u200b\u4f7f\u7528\u200bGPLv3\u200b\u8bb8\u53ef\u8bc1\u200b\u53d1\u5e03\u200b\u7684\u200b\u8f6f\u4ef6\u200b\u90fd\u200b\u4e0d\u200b\u5141\u8bb8\u200b\u901a\u8fc7\u200b\u589e\u52a0\u200b\u9650\u5236\u200b\u6761\u6b3e\u200b\u6765\u200b\u4fb5\u5bb3\u200b\u6700\u7ec8\u7528\u6237\u200b\u7684\u200b\u6743\u5229\u200b\u3002</li> <li>\u200b\u9644\u52a0\u200b\u6761\u6b3e\u200b\uff1a\u200b\u8bb8\u53ef\u8bc1\u200b\u5141\u8bb8\u200b\u9644\u52a0\u200b\u67d0\u4e9b\u200b\u9650\u5236\u200b\u6216\u200b\u63d0\u4f9b\u200b\u9644\u52a0\u200b\u6743\u9650\u200b\uff0c\u200b\u4f46\u200b\u5b83\u4eec\u200b\u4e0d\u80