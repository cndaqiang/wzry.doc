{"config": {"lang": ["en", "ja"], "separator": "[\\s\\-\\.]+", "pipeline": ["stemmer"]}, "docs": [{"location": "", "title": "\u9879\u76ee\u200b\u4ecb\u7ecd", "text": "\u519c\u6d3b\u200b\u81ea\u52a8\u5316\u200b\u52a9\u624b\u200b     \u200b\u4f7f\u7528\u200b\u65b9\u6cd5\u200b, \u200b\u8bf7\u200b\u8bbf\u95ee\u200b: \u200b\u5b89\u88c5\u200b\u6307\u5357\u200b|\u200b\u5907\u7528\u200b\u6307\u5357\u200b|\u200b\u89c6\u9891\u6559\u7a0b\u200b.  \u200b\u9047\u5230\u200b\u95ee\u9898\u200b, \u200b\u8bf7\u200b\u5728\u200b\u63d0\u95ee\u200b\u524d\u200b\u67e5\u770b\u200b: \u200b\u5e38\u89c1\u95ee\u9898\u200b."}, {"location": "#\u514d\u8d23\u58f0\u660e", "title": "\u514d\u8d23\u200b\u58f0\u660e", "text": "<p>\u200b\u519c\u6d3b\u200b\u81ea\u52a8\u5316\u200b\u52a9\u624b\u200b \u200b\u662f\u200b\u57fa\u4e8e\u200b airtest-mobileauto \u200b\u5f00\u53d1\u200b\u7684\u200b\u514d\u8d39\u200b\u5f00\u6e90\u200b\u519c\u6d3b\u200b\u81ea\u52a8\u5316\u200b\u811a\u672c\u200b\uff0c\u200b\u65e8\u5728\u200b\u5e2e\u52a9\u200b\u73a9\u5bb6\u200b\u81ea\u52a8\u5316\u200b\u65e5\u5e38\u200b\u4efb\u52a1\u200b\uff0c\u200b\u8282\u7701\u65f6\u95f4\u200b\uff0c\u200b\u4e13\u6ce8\u200b\u4eab\u53d7\u200b\u751f\u6d3b\u200b\u3002\u200b\u652f\u6301\u200b7*24h \u200b\u5b8c\u5168\u200b\u65e0\u4eba\u200b\u503c\u5b88\u200b\u8fd0\u884c\u200b\uff0c\u200b\u81ea\u52a8\u200b\u542f\u52a8\u200b\u6a21\u62df\u5668\u200b\u3001\u200b\u66f4\u65b0\u200b\u6e38\u620f\u200b\u3001\u200b\u4fee\u590d\u200b\u9519\u8bef\u200b\u3001\u200b\u81ea\u52a8\u200b\u5bf9\u200b\u6218\u53ca\u200b\u9886\u53d6\u200b\u793c\u5305\u200b\u3002</p> <p>\u200b\u9879\u76ee\u200b\u901a\u8fc7\u200b\u56fe\u50cf\u8bc6\u522b\u200b\u548c\u200b\u6a21\u62df\u200b\u70b9\u51fb\u200b\u5b9e\u73b0\u200b\u81ea\u52a8\u5316\u200b\uff0c\u200b\u4e0d\u200b\u4fee\u6539\u200b\u6e38\u620f\u200b\u6570\u636e\u200b\u3002</p> <p>\u200b\u4f7f\u7528\u200b\u672c\u200b\u9879\u76ee\u200b\u7684\u200b\u98ce\u9669\u200b\u7531\u200b\u7528\u6237\u200b\u81ea\u884c\u200b\u627f\u62c5\u200b\uff0c\u200b\u